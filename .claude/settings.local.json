      "Bash(npx convex:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(pnpm remove:*)",
      "Bash(find /mnt/myssd/Web-Development/Nextjs/learning-bitacora/src -type f -name *review* -o -name *challenge*)",
      "Bash(cat /mnt/myssd/Web-Development/Nextjs/learning-bitacora/src/app/\\\\\\(dashboard\\\\\\)/journal/new/page.tsx)",
      "Bash(cat /mnt/myssd/Web-Development/Nextjs/learning-bitacora/src/app/\\\\\\(dashboard\\\\\\)/review/page.tsx)",
      "Bash(ls -la /c/Users/big_h/Documents/Web-Development/Nextjs/learning-bitacora/src/app/\\\\\\(dashboard\\\\\\)/journal/)",
      "Bash(grep -E \"\\\\.\\(ts|js|json\\)$\")",
      "Bash(ls -la /c/Users/big_h/Documents/Web-Development/Nextjs/learning-bitacora/src/app/\\\\\\(dashboard\\\\\\)/)",
      "Bash(npx next:*)",
      "PowerShell(npx tsc --noEmit 2>$null; \"exit: $LASTEXITCODE\")",
      "PowerShell(npx convex data challengeCache --prod --limit 20)",
      "PowerShell(npx convex deploy -y; \"deploy exit: $LASTEXITCODE\")"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe",
            "args": [
              "-NoProfile",
              "-Command",
              "$c = 'Standing instruction: Before addressing the request below, first review the most recent user message for English grammar, spelling, and phrasing. Begin your reply with a short section titled English coaching containing (1) a corrected, more natural version of the message, and (2) one to three concrete tips to improve the writing. Keep it concise, then fully address the request.'; $o = @{ hookSpecificOutput = @{ hookEventName = 'UserPromptSubmit'; additionalContext = $c } }; $o | ConvertTo-Json -Compress"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/capture-writing.ps1"
            ],
            "timeout": 15
          }
        ]
      }
    ]
  }
}
